{
  "name": "autolinear",
  "version": "0.3.0",
  "description": "Autonomous task execution with Linear integration. Picks tasks from Linear, routes to agents via tag-to-command mapping, generates proof-of-work artifacts, and handles reviewer-comment feedback loops. Alpha: manual path (/autolinear:run <id>) is end-to-end; autonomous webhook pickup is wired at the receiver but queue → Claude Code dispatch is a stub.",
  "author": {
    "name": "Jack Rudenko",
    "email": "i@madappgang.com",
    "company": "MadAppGang"
  },
  "license": "MIT",
  "keywords": [
    "autolinear",
    "autonomous",
    "linear",
    "task-execution",
    "proof-of-work",
    "webhook",
    "state-machine",
    "feedback-loop",
    "multi-agent"
  ],
  "category": "automation",
  "agents": [
    "./agents/task-executor.md",
    "./agents/proof-generator.md",
    "./agents/feedback-processor.md"
  ],
  "commands": [
    "./commands/create-task.md",
    "./commands/status.md",
    "./commands/config.md",
    "./commands/run.md",
    "./commands/help.md"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "npmDependencies": {
    "@linear/sdk": "^26.0.0",
    "playwright": "^1.40.0"
  },
  "compatibility": {
    "claudeCode": ">=0.1.0"
  },
  "envVars": {
    "LINEAR_API_KEY": {
      "description": "Linear API key for authentication",
      "required": true,
      "example": "lin_api_xxxxxxxxxxxxx"
    },
    "LINEAR_WEBHOOK_SECRET": {
      "description": "Secret for webhook signature verification",
      "required": true,
      "example": "whsec_xxxxxxxxxxxxx"
    },
    "AUTOLINEAR_WEBHOOK_PORT": {
      "description": "Port for webhook server",
      "required": false,
      "default": "3001"
    },
    "AUTOLINEAR_BOT_USER_ID": {
      "description": "Linear user ID for autolinear bot",
      "required": true,
      "example": "user_xxxxxxxxxxxxx"
    },
    "AUTOLINEAR_MAX_FEEDBACK_ROUNDS": {
      "description": "Maximum feedback iterations before escalation",
      "required": false,
      "default": "5"
    },
    "AUTOLINEAR_CONFIDENCE_THRESHOLD": {
      "description": "Minimum confidence for auto-approval (0-100)",
      "required": false,
      "default": "95"
    }
  }
}
